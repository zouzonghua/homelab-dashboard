{
  "name": "homelab-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd .. && HOMELAB_DB_PATH=data/homelab.db HOMELAB_STATIC_DIR=web/dist PORT=8080 go run ./cmd/server",
    "api:types": "rm -rf ./src/api/contract && openapi-ts -i ../api/openapi.yaml -o ./src/api/contract -p @hey-api/typescript && test -f ./src/api/contract/types.gen.ts",
    "api:types:check": "npm run api:types && git diff --exit-code src/api/contract",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run --passWithNoTests --environment jsdom src",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "e2e:server": "mkdir -p ../.tmp && rm -f ../.tmp/e2e-homelab.db && npm run build && cd .. && HOMELAB_DB_PATH=.tmp/e2e-homelab.db HOMELAB_STATIC_DIR=web/dist PORT=4174 go run ./cmd/server",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-toastify": "^11.0.5"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.96.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.15",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.29",
    "tailwindcss": "^3.3.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
